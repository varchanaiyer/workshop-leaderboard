# Copy this file to .streamlit/secrets.toml and fill in the values.
# DO NOT commit secrets.toml to git.

# GitHub Personal Access Token with repo write permissions
# Create at: https://github.com/settings/tokens → Fine-grained → select repo
GITHUB_TOKEN = "ghp_your_token_here"

# GitHub repo to store submissions (format: "owner/repo-name")
# This repo should exist and be accessible with the token above
GITHUB_REPO = "your-username/workshop-submissions"

# Admin password for the instructor panel
ADMIN_PASSWORD = "your_admin_password_here"
